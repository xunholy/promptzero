# Binaries
zeropilot
/bin/
/dist/

# FAP (Flipper app) build artefacts — ufbt's per-app dist/ + cache.
/fap/*/dist/
/fap/*/.ufbt/

# Project-local Python venv used to install ufbt for FAP builds.
# Created by `python3 -m venv .ufbt-venv && .ufbt-venv/bin/pip install ufbt`.
# Reusable across builds; never check in.
/.ufbt-venv/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Config with secrets (top-level only — examples/ templates are committed)
/config.yaml
/config.yml

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Top-level promptzero binary dropped by `go build` in repo root. Anchored
# with a leading slash so it does NOT match cmd/promptzero/ (which would
# make git silently ignore new files under that directory).
/promptzero

# Claude Code teammate state
.claude/
